# ============================================================
# VESPER DASHBOARD — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- PROXMOX ---
# IP or hostname of your Proxmox node
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your_proxmox_password
# Set to false for self-signed certs (standard homelab)
PROXMOX_VERIFY_SSL=false
# The node name shown in your Proxmox UI (usually 'pve')
PROXMOX_NODE=pve

# --- WEATHER ---
# Free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_key
WEATHER_CITY=London
# metric (°C) or imperial (°F)
WEATHER_UNITS=metric

# --- CALENDAR ---
# Google Calendar iCal URL
# Get it from: Google Calendar > Settings > your calendar
# > "Secret address in iCal format"
ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_CALENDAR_ID/private-TOKEN/basic.ics

# --- RSS FEEDS ---
# Comma-separated list of RSS feed URLs
RSS_FEEDS=https://feeds.bbci.co.uk/news/technology/rss.xml,https://www.theregister.com/headlines.atom

# --- SERVICE HEALTH CHECKS ---
# Format: DisplayName=http://url, DisplayName=http://url
# Vesper checks these URLs every 30 seconds
SERVICES=Proxmox=https://192.168.1.100:8006,Portainer=http://192.168.1.100:9000,Plex=http://192.168.1.100:32400/web

# --- GMAIL (Work side — Inbox widget) ---
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable Gmail API
# Step 3: OAuth 2.0 Credentials → Desktop app → Download JSON
# Step 4: Run once locally to get your refresh token:
#   pip install google-auth-oauthlib
#   python3 -c "
#   from google_auth_oauthlib.flow import InstalledAppFlow
#   flow = InstalledAppFlow.from_client_secrets_file('credentials.json',['https://www.googleapis.com/auth/gmail.readonly'])
#   creds = flow.run_local_server(port=0)
#   print('CLIENT_ID:', creds.client_id)
#   print('CLIENT_SECRET:', creds.client_secret)
#   print('REFRESH_TOKEN:', creds.refresh_token)
#   "
# Step 5: Paste the values below
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
